# Application Configuration
NODE_ENV=production
PORT=80
MICROSERVICE_NAME=crm-backend
ALLOWED_ORIGIN=http://localhost
SERVER_HOST=0.0.0.0
SERVER_PORT=80

# IAM Service (Keycloak) Configuration
IAM_SERVICE_NAME=KEYCLOAK
IAM_REALM=optimce-realm
IAM_REALM_NAME=optimce-realm
IAM_CLIENT_ID=optimce-backend
IAM_GRANT_TYPE=client_credentials
IAM_CLIENT_SECRET=changeme_keycloak_admin_password
IAM_BASE_URL=http://keycloak:8080

# Storage Service (OpenFiles) Configuration
STORAGE_SERVICE_NAME=openfiles
STORAGE_TARGET=http://openfiles:8001
STORAGE_DB_NAME=crm_files
STORAGE_TOKEN=changeme_storage_token

# OpenTelemetry Configuration
REMOTE_LOGGING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Database for crm_backend configuration
DB_TYPE=postgres
DB_HOST=crm-database
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=changeme_db_password
DB_NAME=crm_db


#CRM Database Configuration
CRM_DB_USERNAME=postgres
CRM_DB_NAME=crm_db
CRM_DB_PASSWORD=changeme_db_password
CRM_DB_HOST=crm-database
CRM_DB_PORT=5432

# Keycloak Database Configuration
KEYCLOAK_DB_USERNAME=postgres
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_PASSWORD=changeme_keycloak_db_password
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_DB_HOST=keycloak-db
KEYCLOAK_DB_PORT=5432

# Keycloak Configuration
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin_password
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloak
KC_DB_USERNAME=postgres
KC_DB_PASSWORD=changeme_keycloak_db_password
KC_HOSTNAME=localhost
KC_HTTP_ENABLED=true

# OpenFiles Configuration
OPENFILES_PORT=8001
OPENFILES_DATA_PATH=/var/lib/openfiles

# Frontend build-time configuration (injected during docker image build)
FRONTEND_API_URL=http://localhost/api
FRONTEND_BASE_PATH=/
FRONTEND_KEYCLOAK_REALM=optimce-realm
FRONTEND_KEYCLOAK_URL=http://localhost/keycloak
FRONTEND_KEYCLOAK_CLIENT_ID=optimce-frontend

